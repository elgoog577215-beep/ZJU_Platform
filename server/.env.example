# Server Configuration
PORT=5181
NODE_ENV=production
FRONTEND_URL=https://tuotuzju.com

# Security - CHANGE THESE IN PRODUCTION!
# Generate a secure key: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-min-64-chars

# Admin Password - Must be at least 12 characters with mixed case, numbers and symbols
ADMIN_PASSWORD=ChangeMe123!@#

# Database
DATABASE_FILE=./database.sqlite

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500
AUTH_RATE_LIMIT_MAX=20

# File Upload
MAX_FILE_SIZE=524288000
UPLOAD_DIR=./uploads

# LLM Configuration (Optional - for WeChat parsing)
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api-inference.modelscope.cn/v1
LLM_MODEL=Qwen/Qwen3-8B

# CORS
# Supports comma-separated origins. In production prefer setting CORS_ALLOWED_ORIGINS explicitly.
CORS_ALLOWED_ORIGINS=https://tuotuzju.com,http://118.31.78.72
# Legacy single/multi-origin compatibility field
CORS_ORIGIN=http://localhost:5173,http://localhost:5180

# Session/Cookie
COOKIE_SECURE=true
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=strict

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
