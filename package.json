{
  "name": "portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "zju": "./bin/zju.js",
    "zju-community": "./bin/zju.js"
  },
  "scripts": {
    "dev": "npm run dev:full",
    "dev:client": "vite --host --port 5180",
    "dev:server": "npm --prefix server start",
    "dev:full": "node --input-type=module -e \"import { spawn } from 'node:child_process'; const procs = []; const start = (cmd, args, name) => { const p = spawn(cmd, args, { stdio: 'inherit', shell: process.platform === 'win32' }); p.on('exit', (code) => { if (code && code !== 0) process.exitCode = code; }); procs.push(p); return p; }; start('npm', ['--prefix', 'server', 'start'], 'server'); start('vite', ['--host', '--port', '5180'], 'web'); const shutdown = (sig) => { for (const p of procs) { try { p.kill(sig); } catch {} } process.exit(0); }; process.on('SIGINT', () => shutdown('SIGINT')); process.on('SIGTERM', () => shutdown('SIGTERM'));\"",
    "openspec": "openspec",
    "openspec:init": "openspec init --tools codex,claude,github-copilot --force .",
    "openspec:update": "openspec update --force .",
    "openspec:list": "openspec list --json",
    "openspec:specs": "openspec list --specs --json",
    "openspec:validate": "openspec validate --all",
    "openspec:view": "openspec view",
    "build": "vite build",
    "cap:build:web": "npm run build",
    "cap:add:ios": "cap add ios",
    "cap:sync:ios": "npm run cap:build:web && cap sync ios",
    "cap:open:ios": "cap open ios",
    "lint": "eslint .",
    "postinstall": "npm --prefix server install",
    "preview": "vite preview",
    "setup": "npm install && cd server && npm install && cd .. && npm run build",
    "quality:staged": "lint-staged",
    "check:ai-assistant": "npm --prefix server run check:ai-assistant",
    "check:ai-agents": "npm --prefix server run check:ai-agents",
    "check:wechat-ai": "npm --prefix server run check:wechat-ai",
    "eval:ai-golden": "npm --prefix server run eval:ai-golden",
    "stress:ai": "npm --prefix server run stress:ai",
    "eval:ai-live": "npm --prefix server run eval:ai-live",
    "agents:spec": "npm --prefix server run agents:spec",
    "profiles:refresh": "npm --prefix server run profiles:refresh",
    "search:index:refresh": "npm --prefix server run search:index:refresh",
    "bench:event-profiles": "npm --prefix server run bench:event-profiles",
    "bench:event-assistant-startup": "npm --prefix server run bench:event-assistant-startup",
    "e2e:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/smoke.spec.js --project=chromium",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,css,scss,md,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-three/drei": "^9.100.0",
    "@react-three/fiber": "^8.16.0",
    "@react-three/postprocessing": "^2.16.2",
    "@tailwindcss/typography": "^0.5.19",
    "axios": "1.13.2",
    "clsx": "^2.1.0",
    "compression": "^1.8.1",
    "dompurify": "^3.3.1",
    "framer-motion": "^11.0.0",
    "html-to-image": "^1.11.13",
    "i18next": "^25.7.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "lucide-react": "^0.344.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.6.205",
    "postprocessing": "^6.38.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.3.5",
    "react-router-dom": "^6.22.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "swr": "^2.3.7",
    "tailwind-merge": "^2.2.1",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.35",
    "prettier": "^3.8.1",
    "promptfoo": "^0.121.3",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "overrides": {
    "axios": "1.13.2"
  },
  "pnpm": {
    "overrides": {
      "axios": "1.13.2"
    }
  }
}
